# MD Tree Application Environment Variables

# Port configuration
PORT=3210

# Node environment
NODE_ENV=production

# Data directory (for SQLite database)
DATA_DIR=/app/data

# Security: Cookie signing secret (REQUIRED for production)
# Generate a secure random secret: openssl rand -hex 32
# NEVER commit the actual secret to version control!
COOKIE_SECRET=your_secure_random_secret_here_change_this_in_production

# Performance & Scalability Settings
# Rate limiting: requests per minute per session (default: 300)
RATE_LIMIT_MAX=300

# Max pastes per session (default: 100, protects against DB bloat)
MAX_PASTES_PER_SESSION=100

# Max concurrent exports (PDF/DOCX) to prevent resource exhaustion
# Recommended: 2-5 depending on server resources (default: 3)
# Each export uses ~500MB RAM + CPU
MAX_CONCURRENT_EXPORTS=3

# Internal stats page. Leave disabled for public deployments unless you
# explicitly want to expose the server dashboard.
ENABLE_STATS_PAGE=0

# AI Features
# Default provider/model used when the UI does not override them.
DEFAULT_AI_PROVIDER=groq
DEFAULT_AI_MODEL=openai/gpt-oss-120b

# PDF Export: path to Chromium/Chrome executable for Paged.js rendering.
# Auto-detected from common paths if not set.
# CHROMIUM_BIN=/snap/bin/chromium

# Groq API Key (recommended default)
# Free developer usage is available via https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Optional Google Gemini fallback
# Get your free API key at https://ai.google.dev/
# Free tier: 15 requests/min, 1M tokens/day for Flash model
GEMINI_API_KEY=your_gemini_api_key_here
